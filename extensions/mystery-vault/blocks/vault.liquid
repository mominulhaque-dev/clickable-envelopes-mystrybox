{% comment %}
  Mystery Vault app block. Renders the envelope grid container and boots the
  vault script. All dynamic state comes from the app proxy at runtime, so this
  block itself is static and cache-friendly.

  The proxy base ({{ shop_proxy }}) resolves to /apps/mystery-vault on the
  storefront; Shopify signs and forwards those requests to the app.
{% endcomment %}

<div
  id="mystery-vault"
  class="mystery-vault"
  data-proxy-base="/apps/{{ block.settings.proxy_prefix | default: 'mystery-vault' }}"
  {% if block.settings.campaign_id != blank %}data-campaign="{{ block.settings.campaign_id }}"{% endif %}
  data-logged-in="{{ customer.id | default: '' }}"
  style="--mv-brand: {{ block.settings.brand_color | default: '#5C6AC4' }};"
>
  <div class="mystery-vault__header">
    <h2 class="mystery-vault__title">{{ block.settings.heading | default: 'Mystery Vault' }}</h2>
    {% if block.settings.subheading != blank %}
      <p class="mystery-vault__subheading">{{ block.settings.subheading }}</p>
    {% endif %}
  </div>

  <div class="mystery-vault__status" data-mv-status role="status" aria-live="polite"></div>
  <div class="mystery-vault__grid" data-mv-grid aria-label="Mystery envelopes"></div>

  {% comment %} Result modal, populated by JS on open. {% endcomment %}
  <div class="mystery-vault__modal" data-mv-modal hidden>
    <div class="mystery-vault__modal-card" role="dialog" aria-modal="true" aria-labelledby="mv-modal-title">
      <button type="button" class="mystery-vault__close" data-mv-close aria-label="Close">&times;</button>
      <h3 id="mv-modal-title" data-mv-result-title></h3>
      <p data-mv-result-detail></p>
      <div class="mystery-vault__code" data-mv-result-code hidden>
        <code data-mv-code-value></code>
        <button type="button" data-mv-copy>Copy</button>
      </div>
      <p class="mystery-vault__result-message" data-mv-result-message></p>
    </div>
  </div>
</div>

{{ 'vault.css' | asset_url | stylesheet_tag }}
<script src="{{ 'vault.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Mystery Vault",
  "target": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Mystery Vault"
    },
    {
      "type": "text",
      "id": "subheading",
      "label": "Subheading",
      "default": "Pick an envelope to reveal your reward"
    },
    {
      "type": "text",
      "id": "campaign_id",
      "label": "Campaign ID (optional)",
      "info": "Leave blank to show the most recent active campaign."
    },
    {
      "type": "color",
      "id": "brand_color",
      "label": "Brand color",
      "default": "#5C6AC4"
    },
    {
      "type": "text",
      "id": "proxy_prefix",
      "label": "App proxy subpath",
      "default": "mystery-vault",
      "info": "Must match the app proxy subpath configured for the app."
    }
  ]
}
{% endschema %}
